{
  "$schema": "https://api.vapi.ai/schema/assistant.json",
  "_meta": {
    "niche_id": "max-bilverksted",
    "schema_version": "1.0.0",
    "variables_version": "1.0.0",
    "tools_catalog_version": "1.0.0",
    "pronunciation_dictionary_version": "1.0.0",
    "guardrails_version": "1.0.0",
    "last_updated": "2026-04-18",
    "owner": "younes.amer.2001@gmail.com",
    "notes": "MVP inbound-only config for Max, auto workshop receptionist. Compiled from shared/skeleton-system-prompt.md + max-bilverksted/variables.md."
  },
  "name": "Max — Oslo Bilverksted AS (MVP inbound)",
  "firstMessage": "Hei, du har ringt Oslo Bilverksted AS. Jeg heter Max og er en AI-resepsjonist. Samtalen blir tatt opp så vi kan forbedre tjenesten — si fra hvis du ikke ønsker det. Hva kan jeg hjelpe med?",
  "firstMessageMode": "assistant-speaks-first",
  "endCallMessage": "Takk for at du ringte Oslo Bilverksted AS. Ha en fin dag.",
  "endCallPhrases": ["ha det", "ha det bra", "takk, ha det", "farvel"],

  "model": {
    "provider": "openai",
    "model": "gpt-4o-mini",
    "temperature": 0.3,
    "maxTokens": 300,
    "systemPrompt": "SEE shared/skeleton-system-prompt.md rendered with max-bilverksted/variables.md — this field gets replaced at deploy time by the variables-resolver.",
    "_systemPromptSource": {
      "template": "../shared/skeleton-system-prompt.md",
      "variables_file": "./variables.md",
      "resolver": "scripts/resolve-variables.ts"
    }
  },

  "voice": {
    "provider": "azure",
    "voiceId": "nb-NO-FinnNeural",
    "speakingRate": 1.00,
    "pitch": 0,
    "style": "default",
    "chunkPlan": {
      "enabled": true,
      "minCharacters": 30,
      "punctuationBoundaries": [".", "!", "?", ";", ":", "—"]
    },
    "fallbackPlan": {
      "voices": [
        { "provider": "azure", "voiceId": "nb-NO-PernilleNeural" }
      ]
    }
  },

  "transcriber": {
    "provider": "azure",
    "language": "nb-NO",
    "endpointingMilliseconds": 450,
    "smartEndpointing": true,
    "fallbackPlan": {
      "transcribers": [
        {
          "provider": "deepgram",
          "model": "nova-3",
          "language": "no",
          "smartFormat": true,
          "endpointing": 450
        }
      ]
    }
  },

  "languageDetection": {
    "enabled": true,
    "primary": "nb-NO",
    "detectables": ["en-US"],
    "switchPolicy": "mirror-once-confirmed"
  },

  "responseDelaySeconds": 0.7,
  "numWordsToInterruptAssistant": 2,
  "silenceTimeoutSeconds": 30,
  "maxDurationSeconds": 480,
  "backgroundSound": "office",
  "backgroundDenoisingEnabled": true,

  "recordingEnabled": true,
  "hipaaEnabled": false,
  "_recording_notes": "Disclosure sagt i firstMessage (G3). stop_recording-tool tilgjengelig. Retention 60 dager (verkstedsdata er mindre sensitivt enn helse).",

  "tools": [
    {
      "type": "function",
      "function": { "name": "query_company_knowledge" },
      "_ref": "../shared/tools-katalog.md §3"
    },
    {
      "type": "function",
      "function": { "name": "check_availability" },
      "_ref": "../shared/tools-katalog.md §4"
    },
    {
      "type": "function",
      "function": { "name": "book_appointment" },
      "_ref": "../shared/tools-katalog.md §5"
    },
    {
      "type": "function",
      "function": { "name": "create_ticket" },
      "_ref": "../shared/tools-katalog.md §6"
    },
    {
      "type": "function",
      "function": { "name": "send_sms_booking_link" },
      "_ref": "../shared/tools-katalog.md §7"
    },
    {
      "type": "function",
      "function": { "name": "send_sms_callback_confirmation" },
      "_ref": "../shared/tools-katalog.md §8"
    },
    {
      "type": "function",
      "function": { "name": "stop_recording" },
      "_ref": "../shared/tools-katalog.md §10"
    },
    {
      "type": "transferCall",
      "destinations": [
        {
          "type": "number",
          "number": "+4792850000",
          "message": "Kobler deg til verkstedet. Et øyeblikk.",
          "description": "primary — verkstedtelefon"
        },
        {
          "type": "number",
          "number": "+4792851111",
          "message": "Kobler deg til verkstedleder. Et øyeblikk.",
          "description": "secondary — verksted-eier"
        }
      ],
      "mode": "warm-transfer-say-message"
    },
    {
      "type": "endCall"
    }
  ],

  "knowledgeBase": {
    "provider": "custom",
    "toolBased": true,
    "_notes": "query_company_knowledge → Trieve backend. file_id: kb_max_bilverksted_v1."
  },

  "messageConfig": {
    "fillerMessages": {
      "enabled": true,
      "nb-NO": [
        "Et øyeblikk, jeg sjekker kalenderen.",
        "Jeg henter prisen raskt.",
        "Sekund."
      ],
      "en-US": [
        "One moment, checking the calendar.",
        "Give me a second.",
        "One moment."
      ]
    },
    "idleMessages": [
      "Er du der fortsatt?"
    ],
    "idleMessageMaxSpokenCount": 2,
    "voicemailMessage": "Hei, dette er Oslo Bilverksted AS. Vi er stengt akkurat nå. Send en SMS til nummeret du ringte, eller ring igjen i åpningstiden — mandag til fredag kl 07:30 til 16:30."
  },

  "serverUrl": "https://api.arxon.no/vapi/webhook",
  "serverUrlSecret": "env:VAPI_WEBHOOK_SECRET",
  "_webhook_security": "HMAC-SHA256 signert per ../shared/tools-katalog.md §11",

  "analysisPlan": {
    "summaryPlan": {
      "enabled": true,
      "messages": [
        {
          "role": "system",
          "content": "Oppsummer samtalen i 3-5 punkter på norsk. Fokus: intent (booking/pris/klage/tauing/annet), utfall, tools brukt, evt. oppfølging nødvendig."
        }
      ]
    },
    "successEvaluationPlan": {
      "enabled": true,
      "rubric": "Samtalen er vellykket hvis: (1) kundens intent er adressert, (2) ingen scope-brudd (ingen diagnose gitt), (3) ved taue-akutt: Viking/NAF/110 henvist korrekt, (4) ved booking: reg.nr bekreftet + SMS sendt, (5) 'fra'-pris brukt riktig.",
      "timeoutSeconds": 30
    },
    "structuredDataPlan": {
      "enabled": true,
      "schema": {
        "type": "object",
        "properties": {
          "intent": { "type": "string", "enum": ["booking", "replan", "cancel", "pricing", "complaint", "roadside", "callback", "other"] },
          "outcome": { "type": "string", "enum": ["completed", "escalated", "callback_scheduled", "roadside_redirect", "abandoned"] },
          "service_type": { "type": "string", "nullable": true },
          "booking_id": { "type": "string", "nullable": true },
          "ticket_id": { "type": "string", "nullable": true },
          "customer_name": { "type": "string", "nullable": true },
          "customer_phone": { "type": "string", "nullable": true },
          "regnr": { "type": "string", "nullable": true },
          "regnr_confirmed_nato": { "type": "boolean" },
          "price_quoted_as_range": { "type": "boolean" },
          "roadside_triggered": { "type": "boolean" },
          "language_switched": { "type": "boolean" },
          "guardrail_violations": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["intent", "outcome", "regnr_confirmed_nato", "price_quoted_as_range", "roadside_triggered", "language_switched"]
      }
    }
  },

  "_deploy_checklist": {
    "required_before_live": [
      "Pris-liste i KB matcher kalendersystemet",
      "Sesong-slots (lør-dekk) korrekt markert mars-april + okt-nov",
      "NATO-alfabet-testing gjennomført for reg.nr-readback",
      "Viking 06000, NAF 08505, 110 siffer-for-siffer-lest",
      "Stemme nb-NO-FinnNeural prøvekjørt (EU-kontroll, Peugeot, Hyundai)",
      "'fra'-pris-rule: ingen fast-pris-løfte på ikke-standard jobber",
      "Lånebil-policy oppdatert i KB",
      "S1–S15 + M1–M7 regresjonstester: 17/18 pass (M2, M4 må være 100%)",
      "serverUrlSecret rotert og lagret i vault"
    ]
  },

  "_references": {
    "skeleton_prompt": "../shared/skeleton-system-prompt.md",
    "variables": "./variables.md",
    "scenarios": "./scenarios.md",
    "pronunciation": "./pronunciation-dictionary.md",
    "master_plan": "./inbound-master-plan.md",
    "guardrails": "../shared/guardrails.md",
    "tools_catalog": "../shared/tools-katalog.md",
    "fallback_no": "../shared/fallback-bibliotek-no.md",
    "fallback_en": "../shared/fallback-bibliotek-en.md"
  }
}
